terraform {
  required_providers {
    launchdarkly = {
      source  = "launchdarkly/launchdarkly"
      version = "~> 2.0"
    }
  }
}

variable "launchdarkly_access_token" {
  type      = string
  sensitive = true
}

variable "project_key" {
  type    = string
  default = "default"
}

variable "environment_key" {
  type    = string
  default = "test"
}

variable "demo_key_prefix" {
  type    = string
  default = ""
}

locals {
  key_prefix                    = trim(var.demo_key_prefix, "-")
  key_prefix_with_separator     = local.key_prefix == "" ? "" : "${local.key_prefix}-"
  landing_hero_flag_key         = "${local.key_prefix_with_separator}new-landing-page-hero"
  support_chatbot_ai_config_key = "${local.key_prefix_with_separator}support-chatbot-ai-config"
  experiment_cohort             = "${local.key_prefix_with_separator}landing-page-q3"
}

provider "launchdarkly" {
  access_token = var.launchdarkly_access_token
}

resource "launchdarkly_feature_flag" "landing_hero" {
  project_key = var.project_key
  key         = local.landing_hero_flag_key
  name        = local.landing_hero_flag_key
  description = "LaunchDarkly SE demo flag for safe release, targeting, and remediation."

  variation_type = "boolean"

  variations {
    name  = "true"
    value = true
  }

  variations {
    name  = "false"
    value = false
  }

  defaults {
    on_variation  = 1
    off_variation = 1
  }

  client_side_availability {
    using_environment_id = true
    using_mobile_key     = false
  }

  tags = ["se-demo"]
}

resource "launchdarkly_feature_flag_environment" "test" {
  flag_id = launchdarkly_feature_flag.landing_hero.id
  env_key = var.environment_key

  on            = false
  off_variation = 1

  fallthrough {
    variation = 1
  }

  targets {
    values    = ["alice-beta-001"]
    variation = 0
  }

  rules {
    variation = 0

    clauses {
      context_kind = "user"
      attribute    = "plan"
      op           = "in"
      values       = ["enterprise"]
      negate       = false
    }
  }

  rules {
    variation = 1

    clauses {
      context_kind = "user"
      attribute    = "experimentCohort"
      op           = "in"
      values       = [local.experiment_cohort]
      negate       = false
    }
  }
}

resource "launchdarkly_feature_flag" "support_chatbot_ai_config" {
  project_key = var.project_key
  key         = local.support_chatbot_ai_config_key
  name        = "Support chatbot AI config"
  description = "JSON config flag used as the AgentControl fallback for chatbot prompt and model control."

  variation_type = "json"

  variations {
    name = "concise"
    value = jsonencode({
      name                = "Concise support guide"
      model               = "gpt-4o-mini"
      temperature         = 0.2
      systemPrompt        = "You are an ABC SaaS support assistant. Give concise, accurate answers, ask one clarifying question when needed, and recommend escalation for account-specific issues."
      welcomeMessage      = "Ask about onboarding, billing, incidents, or release safety."
      responseStyle       = "concise"
      escalationThreshold = 0.7
    })
  }

  variations {
    name = "empathetic"
    value = jsonencode({
      name                = "Empathetic escalation guide"
      model               = "gpt-4o"
      temperature         = 0.45
      systemPrompt        = "You are an empathetic ABC SaaS support assistant. Reassure the customer, provide step-by-step help, and escalate quickly for account-specific or incident-impacting questions."
      welcomeMessage      = "Ask me about a support issue and I will guide the next safe action."
      responseStyle       = "empathetic"
      escalationThreshold = 0.55
    })
  }

  defaults {
    on_variation  = 0
    off_variation = 0
  }

  client_side_availability {
    using_environment_id = true
    using_mobile_key     = false
  }

  tags = ["se-demo", "ai-config"]
}

resource "launchdarkly_feature_flag_environment" "support_chatbot_ai_config_test" {
  flag_id = launchdarkly_feature_flag.support_chatbot_ai_config.id
  env_key = var.environment_key

  on            = false
  off_variation = 0

  fallthrough {
    variation = 0
  }
}
