VITE_LD_CLIENT_ID=your-launchdarkly-client-side-id
VITE_LD_HERO_FLAG_KEY=new-landing-page-hero
VITE_LD_AI_CONFIG_KEY=support-chatbot-ai-config
VITE_LD_EXPERIMENT_EVENT_KEY=hero-cta-clicked
VITE_LD_EXPERIMENT_COHORT=landing-page-q3
LD_REMEDIATION_TRIGGER_URL=https://app.launchdarkly.com/webhook/triggers/replace-me

# Export LD_API_TOKEN in your terminal when running setup or cleanup.
# Do not store real LaunchDarkly API tokens in .env files.
LD_PROJECT_KEY=default
LD_ENV_KEY=test
LD_CREATE_TRIGGER=true
# Optional: avoid shared-tenant key collisions. The setup script writes matching VITE_* keys to .env.
# LD_DEMO_KEY_PREFIX=your-name-or-initials
# Set only when intentionally deleting REST-created demo resources.
# LD_CLEANUP_CONFIRM=delete-demo-resources
